# Copy this file to `.env` and fill in real values.
# The .env file is gitignored — never commit real keys.

# Groq (Whisper STT). Get from https://console.groq.com/keys
GROQ_API_KEY=

# Deepseek (translation). Get from https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Anthropic (summarization). Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Gemini (daily summarization). Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Telegram Bot. Create via @BotFather on Telegram, then /newbot.
TELEGRAM_BOT_TOKEN=

# Your personal Telegram chat ID (where the bot will send results).
# To find it: message your bot once, then visit
#   https://api.telegram.org/bot<TELEGRAM_BOT_TOKEN>/getUpdates
# and look for "chat":{"id": ...}
TELEGRAM_CHAT_ID=

# Optional: downstream radio_kg auto-ingest after a successful pipeline.
# The root ../agent-up.command sets these automatically.
RADIO_KG_AUTO_INGEST=0
RADIO_KG_AUTO_INGEST_URL=http://127.0.0.1:8000/api/ingest
