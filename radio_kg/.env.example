# ── LLM provider ───────────────────────────────────────────────
# One of: anthropic | openai | deepseek | mimo
LLM_PROVIDER=anthropic
LLM_MODEL=                       # optional override; sensible default per provider

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=                # DeepSeek uses the OpenAI-compatible endpoint
MIMO_API_KEY=                    # MiMo uses the OpenAI-compatible endpoint
MIMO_BASE_URL=https://api.mimo-v2.com/v1

# ── Neo4j (local, started via `brew services start neo4j`) ──────
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ── Docker Compose ports / Neo4j memory ────────────────────────
APP_PORT=8000
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_HEAP_INITIAL=512m
NEO4J_HEAP_MAX=2G
NEO4J_PAGECACHE=1G

# ── MCP servers (launched on demand via uvx) ───────────────────
# Graph: official Neo4j Cypher MCP server
MCP_NEO4J_COMMAND=uvx
MCP_NEO4J_ARGS=mcp-neo4j-cypher
# Vector: official Chroma MCP server (local persistent client)
MCP_CHROMA_COMMAND=uvx
MCP_CHROMA_ARGS=chroma-mcp

# ── Local storage paths ────────────────────────────────────────
CHROMA_PATH=./data/chroma
VECTOR_EMBEDDING_MODEL=intfloat/multilingual-e5-base
VECTOR_COLLECTION=
VECTOR_BATCH_SIZE=16
QA_ANSWER_MAX_TOKENS=8192
QA_VECTOR_K=32
QA_TOP_N=48
QA_SUMMARY_K=24
QA_DIRECT_K=16
QA_FALLBACK_K=32
CHECKPOINT_DB=./data/checkpoints.sqlite
PENDING_DIR=./data/pending

# ── Source data ────────────────────────────────────────────────
# ../Radio/data/recordings consumes the upstream Radio producer output directly
# (each subfolder is a collection). source_data.py also accepts a flat layout
# (<episode>/03_ja_segments.json) if RADIO_DATA_DIR points at one.
RADIO_DATA_DIR=../Radio/data/recordings
PROGRAM_NAME=羊宮妃那のこもれびじかん

# ── Clipper（数据驱动型内容二次创作，独立功能；均有默认值，可不填）──────────
# B 站分区：逗号分隔的分区名或数字 rid（music,game,douga,dance,vtuber,anime,life...）
BILIBILI_PARTITIONS=music,game,douga
# 可选 cookie（匿名也能跑大多数榜单；填了更稳）
# BILIBILI_SESSDATA=
CLIP_HOURS_WINDOW=48          # 只看最近 N 小时（相对本批最新稿件）
CLIP_TOPK=5                   # 保留的热点/片段数
CLIP_MIN_SCORE=0.45           # 相关性/爆火分阈值
CLIP_PAD_SEC=1.5              # 切片首尾 padding
CLIP_VIDEO_RES=720            # Branch B yt-dlp 下载分辨率上限
CLIP_OUTPUT_DIR=./data/clips
# 歌词三档：netease=授权网易云检索（默认）| file=仅用户自备 .srt/.lrc | placeholder=只显示占位
LYRICS_MODE=netease
# 本地/自有 NeteaseCloudMusicApi 服务；本项目不会调用公开镜像
LYRICS_NETEASE_BASE_URL=http://127.0.0.1:3000
# 如授权服务需要账号态，可填 NeteaseCloudMusicApi 支持的 cookie 参数
# LYRICS_NETEASE_COOKIE=
LYRICS_NETEASE_TIMEOUT_SEC=8
LYRICS_SEARCH_LIMIT=5
LYRICS_NETEASE_MATCH_SCORE=0.62
LYRICS_MATCH_MIN_SCORE=0.45
LYRICS_OFFICIAL_MIN_SCORE=0.78
# WhisperX 词级对齐（装在独立 venv，见 README）
WHISPERX_PYTHON=./.venv_whisperx/bin/python
WHISPERX_DEVICE=cpu           # cpu | cuda
WHISPERX_COMPUTE_TYPE=int8    # int8(cpu) | float16(cuda)
WHISPERX_MODEL=small
WHISPERX_LANGUAGE=ja
